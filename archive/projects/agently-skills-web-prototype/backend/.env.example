# 后端配置示例（不要提交真实 .env）

# workspace_root：SDK 会在这里输出 WAL/事件证据链（JSONL）
AGENTLY_SKILLS_WEB_WORKSPACE_ROOT=.runtime/workspace

# SDK overlays（YAML），用于 preflight/scan/run（后者覆盖前者）
AGENTLY_SKILLS_WEB_SDK_CONFIG_PATHS=config/sdk.demo.yaml

# run mode：
# - demo：离线 scripted backend（默认）
# - real：使用 Agently OpenAICompatible requester（需要安装 agently，并且有可用的模型配置）
AGENTLY_SKILLS_WEB_RUN_MODE=demo

