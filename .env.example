# capability-runtime（示例）
#
# 说明：
# - 不要把真实密钥提交到仓库；本文件仅用于说明“需要哪些 env var”以及它们的语义。
# - 生产推荐：由部署系统注入 OS env（镜像外部挂载/注入），服务启动时加载到进程环境。
# - 实际使用哪些 env var 以你的 SDK overlays 为准（例如 `config/sdk.local.yaml` 中的 `llm.api_key_env` / skills sources 的 `dsn_env`）。

# LLM API Key（示例：OpenAI-compatible）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
MODEL_NAME=YOUR_PROVIDER_MODEL

# Optional: only for controlled private providers that must use http://.
# Prefer HTTPS. Real release gates should also restrict trusted hosts.
CAPRT_REAL_PROVIDER_ALLOW_INSECURE_TRANSPORT=0

# Runtime provider requester strategy（可选）：chat_completions 或 responses。
# 默认仍是 chat_completions；responses 必须显式 opt-in。
REQUESTER_STRATEGY=chat_completions

# Skills sources（可选示例）
REDIS_URL=
SKILLS_PG_DSN=
