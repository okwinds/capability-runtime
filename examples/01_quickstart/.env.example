# OpenAI-compatible provider 配置（示例）
OPENAI_API_KEY="YOUR_API_KEY"
OPENAI_BASE_URL="https://api.openai.com/v1"

# Runtime bridge 的实际请求模型必须通过 AgentSpec.llm_config.model / SDK ChatRequest.model 生效。
# 不要只依赖 transport/requester settings 里的 model。
MODEL_NAME="YOUR_PROVIDER_MODEL"

# 可选：仅受控私有 provider 且必须使用 http:// 时设为 "1"；默认应使用 HTTPS。
CAPRT_REAL_PROVIDER_ALLOW_INSECURE_TRANSPORT="0"
